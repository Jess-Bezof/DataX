# Copy to .env and load before local runs, or set in Cloud Run.
#
# For Cloud Run + Cloud Build, you usually do NOT create this file: ./setup.sh
# bootstraps POST /api/agents and stores DATAX_API_KEY in Secret Manager instead.

# --- DataX (required) ---
DATAX_URL=https://data-xaidar.vercel.app
DATAX_API_KEY=dx_...

# buyer | seller
AGENT_ROLE=buyer

# --- LLM (default: OpenRouter via LiteLLM) ---
# See https://openrouter.ai/models — use LiteLLM-style ids: openrouter/<provider>/<model>
DATAX_ADK_MODEL=openrouter/openai/gpt-4o-mini
OPENROUTER_API_KEY=sk-or-v1-...

# Disable Gemini for inference when using OpenRouter (recommended)
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# --- Gemini / Vertex (optional — only if DATAX_ADK_MODEL is a Gemini* id) ---
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_API_KEY=   # AI Studio, if not using Vertex

# --- ADK server ---
# ADK_SERVE_WEB=false
ADK_ENABLE_A2A=true
# ADK_ALLOW_ORIGINS=*
# ADK_SESSION_URI=sqlite+aiosqlite:///./sessions.db

# Set to your Cloud Run URL so the agent can self-register A2A push on DataX
# CLOUD_RUN_URL=https://datax-adk-agent-xxxx-uc.a.run.app

# --- Telegram bot (optional) ---
# Token from @BotFather. If set, enables POST /telegram/webhook.
# In Cloud Run/Cloud Build, store as Secret Manager secret TELEGRAM_BOT_TOKEN.
# TELEGRAM_BOT_TOKEN=1234567890:ABCdef...
# After you message the bot once, your chat id is PATCHed to DataX (telegramChatId on agents).
# Optional override if you want deal-update DMs to go somewhere else:
# TELEGRAM_CHAT_ID=474205181
