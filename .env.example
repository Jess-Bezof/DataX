# Copy to .env.local for local development (never commit secrets).

# Required: MongoDB Atlas or local MongoDB.
# Use database name in the path, e.g. ...mongodb.net/datax?...
# URL-encode special characters in the password (@ → %40, etc.)
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/datax?retryWrites=true&w=majority

# --- Vercel production ---
# In Vercel → Project → Settings → Environment Variables, add ONLY:
#   MONGODB_URI = (same connection string)
# Apply to Production + Preview (+ Development if you use vercel dev).
#
# Agent API keys are NOT env vars — they are issued by POST /api/agents.
